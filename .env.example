# Copy to .env for local development. Every variable below has a working
# default (see src/media_platform/config.py) - nothing here is required
# to start the bootstrap application.

ENVIRONMENT=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=text

# Provider selection - each defaults to a null/in-memory bootstrap
# adapter. Switch these once a real adapter is configured (below).
SEARCH_PROVIDER=null
STORAGE_PROVIDER=null
DATABASE_PROVIDER=memory
AUTH_PROVIDER=null
METADATA_PROVIDER=null
STREAMING_PROVIDER=null
TELEGRAM_PROVIDER=null

# --- Real adapters (Phase 3) ------------------------------------------------
# Uncomment and fill in to use the mongo/kurigram adapters instead of the
# bootstrap defaults. Requires the matching extra:
#   pip install -e ".[mongo]"      for DATABASE_PROVIDER=mongo / SEARCH_PROVIDER=mongo_text
#   pip install -e ".[telegram]"   for TELEGRAM_PROVIDER=kurigram
#
# DATABASE_PROVIDER=mongo
# SEARCH_PROVIDER=mongo_text
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net
#
# TELEGRAM_PROVIDER=kurigram
# BOT_TOKEN=123456:your-bot-token
# API_ID=12345
# API_HASH=your-api-hash
#
# STORAGE_PROVIDER=telegram         # serves file bytes from Telegram for streaming/download
# STREAMING_PROVIDER=signed         # issues HMAC-signed, expiring playback URLs
# STREAM_SECRET=change-me-to-a-long-random-value
# PUBLIC_BASE_URL=https://your-deployment.example.com
# STREAM_URL_EXPIRY_SECONDS=21600
# STREAM_CHUNK_SIZE=1048576
# STREAM_WORKER_TOKENS=              # optional comma-separated extra bot tokens for the
#                                     # streaming worker pool; falls back to BOT_TOKEN alone

# Bounded cache (see docs/architecture/overview.md - replaces every
# unbounded global dict found in the reference bots)
CACHE_MAX_SIZE=512
CACHE_TTL_SECONDS=300

# Comma-separated plugin names to skip loading entirely (never imported,
# not just disabled at runtime) - see architecture-design-phase1-v3.md §3.
PLUGINS_DISABLED=
